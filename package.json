    "@nuxtjs/tailwindcss": "^6.14.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.25.0",
    "nuxt": "^4.4.2",
    "nuxt-phosphor-icons": "^2.3.3",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
